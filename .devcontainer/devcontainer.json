{
  "image": "mcr.microsoft.com/devcontainers/ruby:4",
  "postCreateCommand": "gem install irb",
  "postAttachCommand": {
    "Open terminal": "echo 'Ready: ruby main.rb'"
  },
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.hideOnStartup": "never",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
